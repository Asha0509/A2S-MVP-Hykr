# ================================================
# A2S Environment Variables
# Copy this file to .env and fill in your values
# ================================================

# ── Azure SQL Server Database ──
SERVER=your-server.database.windows.net
DATABASE=your-database-name
DB_USERNAME=sqladmin
DB_PASSWORD=your-password

# ── Spring Boot Backend (JDBC format) ──
DB_URL=jdbc:sqlserver://your-server.database.windows.net:1433;database=your-db;encrypt=true;trustServerCertificate=false
DB_USER=sqladmin
DB_DRIVER=com.microsoft.sqlserver.jdbc.SQLServerDriver
DB_DIALECT=org.hibernate.dialect.SQLServerDialect

# ── JWT Secret ──
JWT_SECRET=change-me-to-a-random-64-character-string

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,https://your-frontend.azurestaticapps.net

# ── AI Room Staging — primary backend: fal.ai (FLUX.1-dev img2img) ──
# https://fal.ai/dashboard/keys → create key. Free tier ≈ 100 img2img calls.
FAL_API_KEY=your_fal_key
FAL_IMG2IMG_MODEL=fal-ai/flux/dev/image-to-image

# ── AI Room Staging — fallback backend: Cloudflare Workers AI ──
# Free tier: 10,000 neurons/day (no credit card required).
# Account ID: dash.cloudflare.com → right sidebar → "Account ID"
# API token:  dash.cloudflare.com/profile/api-tokens → "Workers AI" template
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token
CF_IMG2IMG_MODEL=@cf/runwayml/stable-diffusion-v1-5-img2img

# ── Google Gemini API (legacy — kept for backwards compat, no longer used) ──
GEMINI_API_KEY=your_gemini_api_key

# ── Groq API ──
GROQ_API_KEY=your_groq_api_key

# ── NVIDIA NIM (recommended for robust auto-direction inference) ──
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key
NVIDIA_NIM_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_NIM_MODEL=meta/llama-3.2-90b-vision-instruct
VASTU_AUTO_MIN_CONFIDENCE=0.65
VASTU_AUTO_TARGET_ACCURACY=0.87

# ── LLM Service URL ──
LLM_SERVICE_URL=http://localhost:5001

# ── Frontend ──
VITE_API_URL=/api

# ── Azure Computer Vision (optional) ──
Azure_Key=your_azure_cv_key
Azure_EndPoint=https://your-cv.cognitiveservices.azure.com/

# ── OAuth2 (optional) ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Azure Key Vault (preferred secret store; falls back to env vars) ──
# When set, LLM/config.py's get_secret() reads from Key Vault first.
# Secret names use lower-kebab form (e.g. NVIDIA_NIM_API_KEY → nvidia-nim-api-key).
# In production, grant the Container App's managed identity get + list on this vault.
# Leave blank for local dev — env vars below will be used directly.
AZURE_KEY_VAULT_URI=https://your-vault-name.vault.azure.net/

# ── Affiliate Tracking (required for revenue attribution) ──
# If blank, scraper falls back to normal non-commission links.
AMAZON_ASSOCIATE_TAG=your-amazon-associate-tag
FLIPKART_AFFILIATE_ID=your-flipkart-affiliate-id
IKEA_AFFILIATE_CODE=your-ikea-affiliate-campaign-code
PEPPERFRY_AFFILIATE_ID=your-pepperfry-affiliate-id
URBANLADDER_AFFILIATE_ID=your-urbanladder-affiliate-id
WOODENSTREET_AFFILIATE_ID=your-woodenstreet-affiliate-id
HOMELANE_AFFILIATE_ID=your-homelane-affiliate-id
NILKAMAL_AFFILIATE_ID=your-nilkamal-affiliate-id
GODREJINTERIO_AFFILIATE_ID=your-godrejinterio-affiliate-id
MIRADORHOME_AFFILIATE_ID=your-miradorhome-affiliate-id
